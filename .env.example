# Core
REDIS_URL=redis://localhost:6379
OPENAI_API_KEY=

# Reasoning engine, rule mode works without API keys
REASONER_PROVIDER=akash
USE_LLM_REASONING=true
AKASHML_API_KEY=
AKASH_BASE_URL=https://api.akashml.com/v1
AKASH_MODEL=meta-llama/Llama-3.3-70B-Instruct

# TinyFish, empty key uses mock mode
TINYFISH_API_KEY=
USE_MOCK_TINYFISH=true

# Vapi, empty key uses mock mode
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=
VAPI_WEBHOOK_URL=
USE_MOCK_VAPI=true
VAPI_TIMEOUT_SECONDS=45

# Demo behavior
AUTO_VERIFY=false
DEMO_VERIFY_BUTTON=true

# Guild.ai
GUILD_WORKSPACE_ID=zxc
GUILD_WORKSPACE_URL=https://app.guild.ai/users/akhileshwar.songala/workspaces/zxc
GUILD_AGENT_NAME=crm-heal

# Ghost by TigerData, empty URL skips persistence visibly
GHOST_DB_URL=
